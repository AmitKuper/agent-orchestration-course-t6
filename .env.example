# MCP inter-server authentication
MCP_API_KEY=your_shared_key_here
MCP_ALLOWED_API_KEYS=your_shared_key_here

# Pluggable actor (Q-table)
ACTOR_CLASS=actor_t6.qtable_actor.QTableActor
COP_ACTOR_TABLE=models/cop_qtable.npy
THIEF_ACTOR_TABLE=models/thief_qtable.npy

# LLM backend — Anthropic or local Ollama
# Option A: Anthropic
ANTHROPIC_API_KEY=

# Option B: local Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:4b

# Gmail reporting
GMAIL_ENABLED=false
GMAIL_RECIPIENT=recipient@example.com
GMAIL_TOKEN_PATH=config/gmail_token.json
GMAIL_CREDENTIALS_PATH=config/gmail_credentials.json
REPORT_TYPE=bonus

# Display name shown in emails and game reports
PLAYER_NAME=YourTeamName

# Report metadata
GROUP_NAME=group-a-t6
GITHUB_REPO=https://github.com/AmitKuper/agent-orchestration-course-t6
